generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String

  trips     Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id          String   @id @default(uuid())
  title       String
  location    String   
  description String?
  countryCode String?
  startDate   DateTime
  endDate     DateTime

  imageUrl    String?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  itinerary ItineraryItem[]
  expenses  Expense[]
  notes     Note[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id        String   @id @default(uuid())
  label     String
  amount    Float

  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Note {
  id        String   @id @default(uuid())
  content   String

  tripId    String   @unique
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model ItineraryItem {
  id          String   @id @default(uuid())

  title       String
  description String?

  date        DateTime
  time        String?   @default("00:00")
  location    String?

  tripId      String
  trip        Trip    @relation( fields: [tripId],references: [id],onDelete: Cascade)

  createdAt DateTime @default(now())
}
